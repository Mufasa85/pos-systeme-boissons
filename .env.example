# =====================================================
# POS BRIKIN — Front-end environment variables
# Copy this file to `.env.local` and adjust the values
# =====================================================

# Base URL of the Express + Sequelize backend.
# Default points to the local dev server (see ../server/.env).
NEXT_PUBLIC_API_BASE_URL=https://raising-remarks-dna-emerald.trycloudflare.com/api

# ---------------------------------------------------------
# Site / SEO metadata
# ---------------------------------------------------------
# Canonical site URL — used for OpenGraph, Twitter, sitemap,
# robots, manifest and JSON-LD structured data. Should be
# the public, https-only, no-trailing-slash URL.
NEXT_PUBLIC_SITE_URL=https://joac.cd

# ---------------------------------------------------------
# Search engine console verifications
# ---------------------------------------------------------
# Paste the meta-tag value (content="...") provided by each
# search engine. Leave empty to omit the verification tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_YAHOO_VERIFICATION=
NEXT_PUBLIC_FB_DOMAIN_VERIFICATION=
NEXT_PUBLIC_PINTEREST_VERIFICATION=

# ---------------------------------------------------------
# Facebook / App Links
# ---------------------------------------------------------
NEXT_PUBLIC_FB_APP_ID=
NEXT_PUBLIC_IOS_APP_ID=
NEXT_PUBLIC_ANDROID_PACKAGE=
